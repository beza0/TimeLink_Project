# Yerel: cp .env.example .env  →  docker compose up -d --build api
#
# ÖNEMLİ — https://www.tiempos.site (canlı) bu dosyayı OKUMAZ.
# Canlı API: Render → Web Service "tiempos-backend-w26e" → Environment.
# Aşağıdaki SPRING_MAIL_* ve APP_MAIL_FROM değerlerini oraya da ekleyin / güncelleyin.
# Gmail Render sunucusundan sık engellenir; canlıda Brevo önerilir.

JWT_SECRET=local-dev-jwt-secret-at-least-32-chars-long

# --- E-posta (doğrulama kodu / şifre sıfırlama) ---
# Gönderici = SMTP hesabı. Alıcı = kayıtta yazılan e-posta (otomatik).
#
# Brevo (önerilen — üretim):
# SPRING_MAIL_HOST=smtp-relay.brevo.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=paneldeki-brevo-giris-e-postaniz@example.com
# SPRING_MAIL_PASSWORD=xsmtpsib-...   # Brevo → SMTP & API → SMTP key (hesap şifresi değil)
# APP_MAIL_FROM=Tiempo <noreply@dogrulanmis-domain.com>   # Brevo'da doğrulanmış gönderici (aynı domain)
# APP_MAIL_STRICT_ERRORS=false   # true ise SMTP hatası kaydı iptal eder (503); üretimde false bırakın
#
# Gmail (yerel test; Render IP'den bazen engellenir):
# SPRING_MAIL_HOST=smtp.gmail.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=you@gmail.com
# SPRING_MAIL_PASSWORD=16-haneli-uygulama-sifresi-bosluksuz
# APP_MAIL_FROM=Tiempo <you@gmail.com>
#
# Yerel Mailpit (gerçek gelen kutusu yok):
# SPRING_MAIL_HOST=mailpit
# SPRING_MAIL_PORT=1025
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=false
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=false
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_REQUIRED=false

SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
APP_MAIL_FROM=
APP_PUBLIC_BASE_URL=https://www.tiempos.site

GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
